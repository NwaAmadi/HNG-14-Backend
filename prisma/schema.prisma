generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  analyst
}

enum OAuthClientKind {
  web
  cli
}

model Profile {
  id                  String   @id @db.Uuid
  name                String   @unique @db.VarChar(255)
  gender              String   @db.VarChar(32)
  gender_probability  Float
  age                 Int
  age_group           String   @db.VarChar(32)
  country_id          String   @db.VarChar(2)
  country_name        String   @db.VarChar(255)
  country_probability Float
  created_at          DateTime @default(now())

  @@index([gender])
  @@index([age_group])
  @@index([country_id])
  @@index([age])
  @@index([gender_probability])
  @@index([country_probability])
  @@index([created_at])
}

model User {
  id                    String                 @id @db.Uuid
  github_id             String                 @unique @db.VarChar(255)
  username              String                 @unique @db.VarChar(255)
  role                  UserRole               @default(analyst)
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  refresh_tokens        RefreshToken[]
  oauth_transactions    OAuthTransaction[]
  cli_authorization_codes CliAuthorizationCode[]

  @@index([role])
  @@index([created_at])
}

model RefreshToken {
  id              String   @id @db.Uuid
  user_id         String   @db.Uuid
  token_hash      String   @unique @db.VarChar(128)
  expires_at      DateTime
  revoked_at      DateTime?
  last_used_at    DateTime?
  created_at      DateTime @default(now())
  user_agent      String?  @db.VarChar(1024)
  ip_address      String?  @db.VarChar(64)
  replaced_by_id  String?  @db.Uuid
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@index([revoked_at])
}

model OAuthTransaction {
  id                       String          @id @db.Uuid
  user_id                  String?         @db.Uuid
  state_hash               String          @unique @db.VarChar(128)
  pkce_verifier            String          @db.VarChar(255)
  client_kind              OAuthClientKind
  redirect_uri             String?         @db.VarChar(2048)
  cli_code_challenge       String?         @db.VarChar(255)
  cli_code_challenge_method String?        @db.VarChar(16)
  expires_at               DateTime
  used_at                  DateTime?
  created_at               DateTime        @default(now())
  user                     User?           @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([expires_at])
  @@index([used_at])
}

model CliAuthorizationCode {
  id                  String   @id @db.Uuid
  user_id             String   @db.Uuid
  code_hash           String   @unique @db.VarChar(128)
  code_challenge      String   @db.VarChar(255)
  code_challenge_method String @db.VarChar(16)
  expires_at          DateTime
  used_at             DateTime?
  created_at          DateTime @default(now())
  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@index([used_at])
}
